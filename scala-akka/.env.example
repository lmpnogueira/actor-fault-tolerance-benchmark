# Akka licence key (Akka BSL). Obtain your own key from https://akka.io
# and place it here. Do NOT commit the real key to version control.
AKKA_KEY=your-akka-licence-key-here

# Optional: host used for the Akka cluster and RabbitMQ broker.
# Defaults to 127.0.0.1 / localhost when unset.
# AKKA_HOST=127.0.0.1
# RABBITMQ_HOST=localhost
